# =========================================
# TelePlay - Complete Stack Configuration
# =========================================
# Copy this file to .env and fill in your values
# =========================================

# -----------------------------------------
# TELEGRAM CONFIGURATION (Required)
# -----------------------------------------

# Get from https://my.telegram.org
TELEGRAM_API_ID=your_api_id
TELEGRAM_API_HASH=your_api_hash

# Get from @BotFather
TELEGRAM_BOT_TOKEN=your_bot_token

# Your storage channel ID (starts with -100)
TELEGRAM_STORAGE_CHANNEL_ID=-100xxxxxxxxxx

# (Optional) Comma separated Telegram IDs of authorized users.
# Leave empty to allow everyone to use the bot.
AUTH_USERS=

# -----------------------------------------
# SECURITY (Required)
# -----------------------------------------

# Generate with: openssl rand -hex 32
JWT_SECRET=your-super-secret-key-change-in-production

# Token expiry in minutes (default: 7 days)
JWT_EXPIRY_MINUTES=10080

# -----------------------------------------
# DATABASE (Docker uses these)
# -----------------------------------------

POSTGRES_USER=postgres
POSTGRES_PASSWORD=your_secure_password
POSTGRES_DB=telegram_tv

# -----------------------------------------
# WEB INTERFACE
# -----------------------------------------

# Public URL where your app is accessible
WEB_BASE_URL=https://your-domain.com

# -----------------------------------------
# PORTS (Optional - change if conflicts)
# -----------------------------------------

BACKEND_PORT=8000
WEB_PORT=80
